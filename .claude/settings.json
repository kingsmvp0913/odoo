{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Bash(**)",
      "Agent(**)",
      "Skill(**)",
      "mcp__github__*"
    ]
  },
  "spinnerTipsEnabled": false,
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "開工",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \".claude/scripts/_pipeline_run.ps1\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Start-Process powershell -WindowStyle Hidden -ArgumentList '-Command \"(New-Object System.Media.SoundPlayer ''C:\\odoo\\.claude\\tools\\notice.wav'').PlaySync()\"' -Wait;",
            "shell": "powershell",
            "statusMessage": "Claude waiting for input..."
          }
        ]
      }
    ]
  }
}
