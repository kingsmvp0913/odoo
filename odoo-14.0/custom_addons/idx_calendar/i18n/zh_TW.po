#. module: idx_calendar
#: model:mail.template,subject:idx_calendar.email_template_meeting_cancelled
msgid "${object.event_id.name}: Cancelled"
msgstr "${object.event_id.name}：已取消"

#. module: idx_calendar
#: model:mail.template,body_html:idx_calendar.email_template_meeting_cancelled
msgid ""
"\n"
"<div>\n"
"    <p>\n"
"        Hello ${object.common_name},<br/><br/>\n"
"        We regret to inform you that the following meeting has been "
"<strong>cancelled</strong>:\n"
"    </p>\n"
"    <ul>\n"
"        <li><strong>Meeting:</strong> ${object.event_id.name}</li>\n"
"        % if not object.event_id.allday:\n"
"            <li><strong>Time:</strong> ${object.event_id.get_display_time_tz"
"(tz=object.partner_id.tz)}</li>\n"
"        % endif\n"
"        % if object.event_id.location:\n"
"            <li><strong>Location:</strong> ${object.event_id.location}</li>\n"
"        % endif\n"
"        <li><strong>Attendees:</strong>\n"
"            <ul>\n"
"            % for attendee in object.event_id.attendee_ids:\n"
"                % if attendee.state != 'declined':\n"
"                    <li>${attendee.common_name}</li>\n"
"                % endif\n"
"            % endfor\n"
"            </ul>\n"
"        </li>\n"
"    </ul>\n"
"    <p>Thank you,</p>\n"
"    % if user.signature:\n"
"        <br/>\n"
"        ${user.signature | safe}\n"
"    % endif\n"
"</div>\n"
msgstr ""
"\n"
"<div>\n"
"    <p>\n"
"        親愛的 ${object.common_name}，您好：<br/><br/>\n"
"        很遺憾通知您，以下會議已<strong>取消</strong>：\n"
"    </p>\n"
"    <ul>\n"
"        <li><strong>會議：</strong> ${object.event_id.name}</li>\n"
"        % if not object.event_id.allday:\n"
"            <li><strong>時間：</strong> ${object.event_id.get_display_time_tz"
"(tz=object.partner_id.tz)}</li>\n"
"        % endif\n"
"        % if object.event_id.location:\n"
"            <li><strong>地點：</strong> ${object.event_id.location}</li>\n"
"        % endif\n"
"        <li><strong>與會者：</strong>\n"
"            <ul>\n"
"            % for attendee in object.event_id.attendee_ids:\n"
"                % if attendee.state != 'declined':\n"
"                    <li>${attendee.common_name}</li>\n"
"                % endif\n"
"            % endfor\n"
"            </ul>\n"
"        </li>\n"
"    </ul>\n"
"    <p>謝謝您。</p>\n"
"    % if user.signature:\n"
"        <br/>\n"
"        ${user.signature | safe}\n"
"    % endif\n"
"</div>\n"
