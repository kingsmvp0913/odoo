<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record model="ir.ui.menu" id="calendar.mail_menu_calendar">
            <field name="action" ref="idx_calendar.action_idx_meeting"/>
        </record>

        <menuitem
                id="menu_calendar"
                name="日曆"
                parent="calendar.mail_menu_calendar"
                action="action_idx_calendar"
                sequence="2"/>
        <menuitem
                id="menu_meeting"
                name="會議"
                parent="calendar.mail_menu_calendar"
                action="action_idx_meeting"
                sequence="1"/>

        <menuitem
                id="menu_calendar_configuration_root"
                name="配置"
                parent="calendar.mail_menu_calendar"
                sequence="3"
                groups="calendar_administrator"/>
            <menuitem name="會議室" id="meeting_room_menu" parent="menu_calendar_configuration_root"
                      action="idx_calendar_meeting_room_action"
                      sequence="1"/>
            <menuitem
                    id="menu_calendar_event_type"
                    name="會議標籤"
                    parent="menu_calendar_configuration_root"
                    action="calendar.action_calendar_event_type"
                    sequence="2"
            />
            <menuitem
                    id="menu_calendar_alarm"
                    name="會議提醒"
                    parent="menu_calendar_configuration_root"
                    action="calendar.action_calendar_alarm"
                    sequence="3"/>
    </data>
</odoo>