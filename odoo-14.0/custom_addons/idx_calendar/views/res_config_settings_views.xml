<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.project.timesheet.event</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_timesheet.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='section_leaves']" position="after">
                <div name="event_timesheet">
                    <h2>會議</h2>
                    <div class="row mt16 o_settings_container" name="event_timesheet_control">
                            <div class="col-12 col-lg-6 o_setting_box" id="event_timesheet_off_validation_setting">
                                <div class="o_setting_left_pane">
                                    <field name="module_project_timesheet_event"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="module_project_timesheet_event"/>
                                    <div class="text-muted">
                                        在創建會議時創建工時表
                                    </div>
                                    <div class="row mt16" attrs="{'invisible': [('module_project_timesheet_event','=',False)]}">
                                        <div class="w-100">
                                            <label for="event_timesheet_project_id" class="col-3 col-lg-3 o_light_label"/>
                                            <field name="event_timesheet_project_id" context="{'active_test': False}" class="oe_inline" attrs="{'required': [('module_project_timesheet_event', '=', True)]}"/>
                                        </div>
                                        <div class="w-100">
                                            <label for="event_timesheet_task_id" class="col-3 col-lg-3 o_light_label"/>
                                            <field name="event_timesheet_task_id" context="{'active_test': False, 'default_project_id': event_timesheet_project_id}" class="oe_inline" attrs="{'required': [('module_project_timesheet_event', '=', True)]}"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
