<odoo>
    <data>
        <record id="view_calendar_event_form_inherit" model="ir.ui.view">
            <field name="name">calendar.event.form.inherit</field>
            <field name="model">calendar.event</field>
            <field name="inherit_id" ref="calendar.view_calendar_event_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='page_misc']" position="replace">
                </xpath>
                <xpath expr="//label[@for='partner_ids']" position="before">
                    <label for="user_id" string="負責人" class="oe_edit_only"/>
                    <h2 options="{'no_open': True,'no_create': True}">
                        <field name="user_id" widget="many2one_avatar_user"
                               options="{'no_open': True,'no_create': True}"/>
                    </h2>
                </xpath>
                <xpath expr="//field[@name='partner_ids']" position="attributes">
                    <attribute name="options">{'no_open': True,'no_create': True}</attribute>
                </xpath>
                <xpath expr="//page[@name='page_details']" position="replace">
                    <page name="page_details" string="會議詳情">
                        <group>
                            <group>
                                <field name="start_date"
                                       attrs="{'required': [('allday','=',True)], 'invisible': [('allday','=',False)]}"
                                       force_save="1"/>
                                <field name="stop_date"
                                       attrs="{'required': [('allday','=',True)],'invisible': [('allday','=',False)]}"
                                       force_save="1"/>

                                <field name="start"
                                       attrs="{'required': [('allday','=',False)], 'invisible': [('allday','=',True)]}"/>
                                <field name="stop" invisible="1"/>
                                <label for="duration" attrs="{'invisible': [('allday','=',True)]}"/>
                                <div attrs="{'invisible': [('allday','=',True)]}">
                                    <field name="duration" widget="float_time" string="Duration" class="oe_inline"
                                           attrs="{'readonly': [('id', '!=', False), ('recurrency','=',True)]}"/>
                                    <span>小時</span>
                                </div>
                                <field name="allday"
                                       attrs="{'readonly': [('id', '!=', False), ('recurrency','=',True)]}"
                                       force_save="1"/>
                            </group>
                            <group>
                                <field name="categ_ids" widget="many2many_tags" options="{'no_create_edit': True}"/>
                                <field name="alarm_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                <field name="event_tz" attrs="{'invisible': [('recurrency', '=', False)]}"/>
                                <field name="meeting_room" widget='radio'/>
                                <field name="meeting_room_name" attrs="{'invisible': [('meeting_room', '=', False)]}"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="project_id" options="{'no_open': True, 'no_create': True}"/>
                                <field name="task_id" options="{'no_open': True, 'no_create': True}" attrs="{'required': [('project_id', '!=', False)]}"/>
                            </group>
                        </group>
                        <group>
                            <field name="note"/>
                        </group>
                        <group>
                            <field name="meeting_url"/>
                        </group>
                        <label for="description"/>
                        <field name="description"/>
                    </page>
                </xpath>
                <xpath expr="//field[@name='privacy']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='privacy']" position="after">
                    <field name="is_chairperson" invisible="1"/>
                </xpath>
                <xpath expr="//page[@name='page_invitations']" position="replace">
                     <page name="page_invitations" string="邀請" attrs="{'invisible': [('is_chairperson', '=', False)]}" >
                            <button name="action_sendmail" type="object" string="發送信件" icon="fa-envelope" class="oe_link"/>
                            <field name="attendee_ids" widget="one2many" mode="tree,kanban" readonly="1">
                                <tree string="邀請詳情" editable="top" create="false" delete="false">
                                    <field name="partner_id" />
                                    <field name="state" />
                                    <field name="email" widget="email"/>

                                    <button name="do_tentative" states="needsAction,declined,accepted" string="不確定" type="object" icon="fa-asterisk" />
                                    <button name="do_accept" string="接受" states="needsAction,tentative,declined" type="object" icon="fa-check text-success"/>
                                    <button name="do_decline" string="拒絕" states="needsAction,tentative,accepted" type="object" icon="fa-times-circle text-danger"/>
                                </tree>
                                <kanban class="o_kanban_mobile" create="false" delete="false">
                                    <field name="partner_id" />
                                    <field name="state" />
                                    <field name="email" widget="email"/>

                                    <templates>
                                        <t t-name="kanban-box">
                                            <div class="d-flex flex-column justify-content-between">
                                                <field name="partner_id"/>
                                                <field name="email" widget="email"/>
                                                <span>Status: <field name="state" /></span>

                                                <div class="text-right">
                                                    <button name="do_tentative" states="needsAction,declined,accepted" string="不確定" type="object" class="btn fa fa-asterisk"/>
                                                    <button name="do_accept" states="needsAction,tentative,declined" string="接受" type="object" class="btn fa fa-check text-success"/>
                                                    <button name="do_decline" states="needsAction,tentative,accepted" string="拒絕" type="object" class="btn fa fa-times-circle text-danger"/>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                </xpath>
            </field>
        </record>

        <!--會議頁面使用-->
        <record id="idx_view_calendar_event_calendar" model="ir.ui.view">
            <field name="name">calendar.event.calendar</field>
            <field name="model">calendar.event</field>
            <field name="priority" eval="2"/>
            <field name="arch" type="xml">
                <calendar js_class="attendee_calendar" string="會議" date_start="start" date_stop="stop"
                          date_delay="duration" all_day="allday"
                          event_open_popup="true"
                          event_limit="5"
                          color="color"
                          mode="month"
                          quick_add="False">
                    <field name="meeting_room" options="{'no_open': True,'no_create': True}"/>
                    <field name="calendar_filters" filters="1" invisible="1"/>
                    <field name="categ_ids" widget="many2many_tags"/>
                    <field name="user_id" string="負責人" filters="1" widget="many2one_avatar_user"/>
                    <field name="partner_ids"/>
                    <field name="meeting_url" string="線上會議連結" widget="url"/>
                    <field name="is_highlighted" invisible="1"/>
                    <field name="description"/>
                    <field name="privacy"/>
                    <field name="attendee_status"/>
                    <!-- For recurrence update Dialog -->
                    <field name="calendar_end_time" invisible="1"/>
                    <field name="recurrency" invisible="1"/>
                    <field name="recurrence_update" invisible="1"/>
                </calendar>
            </field>
        </record>

        <!--日曆頁面使用-->
        <record id="idx_view_calendar_event_calendar2" model="ir.ui.view">
            <field name="name">calendar.event.calendar</field>
            <field name="model">calendar.event</field>
            <field name="priority" eval="2"/>
            <field name="arch" type="xml">
                <calendar js_class="attendee_calendar" string="會議" date_start="start" date_stop="stop"
                          date_delay="duration" all_day="allday"
                          event_open_popup="true"
                          event_limit="5"
                          color="color"
                          mode="month"
                          quick_add="False">
                    <field name="meeting_room" options="{'no_open': True,'no_create': True}"/>
                    <field name="categ_ids" widget="many2many_tags"/>
                    <field name="user_id" filters="1" widget="many2one_avatar_user"/>
                    <field name="partner_ids" widget="many2many_tags_avatar" write_model="calendar.contacts"
                           write_field="partner_id" avatar_field="image_128"/>
                    <field name="meeting_url" string="線上會議連結" widget="url"/>
                    <field name="is_highlighted" invisible="1"/>
                    <field name="description"/>
                    <field name="privacy"/>
                    <field name="attendee_status"/>
                    <!-- For recurrence update Dialog -->
                    <field name="calendar_end_time" invisible="1"/>
                    <field name="recurrency" invisible="1"/>
                    <field name="recurrence_update" invisible="1"/>
                </calendar>
            </field>
        </record>

        <record id="view_calendar_event_search_inherit" model="ir.ui.view">
            <field name="name">calendar.event.search.inherit</field>
            <field name="model">calendar.event</field>
            <field name="inherit_id" ref="calendar.view_calendar_event_search"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='mymeetings']" position="after">
                    <filter string="所有會議" name="all_meetings" domain="[('meeting_room', '!=', False)]"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

