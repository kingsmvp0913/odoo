# ==========================================
# 1. 排除所有虛擬環境 (Python Venv)
# ==========================================
venv_*/
**/venv_*/
**/site-packages/
**/.venv/

# ==========================================
# 2. 排除不重要的 Odoo 核心舊版本（只留下你目前要分析的版本）
# ==========================================
odoo-13.0/
odoo-14.0/
odoo-18.0/

# ==========================================
# 3. 排除 Odoo 核心底層中「不常修改」的巨型模組
# ==========================================
**/odoo/addons/base/
**/odoo/addons/web/
**/odoo/addons/website/

# ==========================================
# 4. 排除 Python 編譯快取與 IDE 暫存檔
# ==========================================
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.vscode/
.git/
.idea/

# ==========================================
# 5. 排除 Odoo 執行產生的日誌與暫存資料
# ==========================================
**/*.log
**/filestore/
**/sessions/

# ==========================================
# 6. 排除 Graphify 自身的輸出與快取
# ==========================================
graphify-out/

# ==========================================
# 7. 排除靜態資源（JS bundle、CSS、圖片、字型）
#    約 5,700 個檔案，不含程式邏輯
# ==========================================
**/static/

# ==========================================
# 8. 排除測試目錄（約 2,855 個檔案）
# ==========================================
**/tests/
**/test/

# ==========================================
# 9. 排除各國本地化模組（約 1,720 個檔案）
#    這些模組與台灣業務通常無關
# ==========================================
addons/l10n_*/

# ==========================================
# 10. 排除示範資料與文件目錄
# ==========================================
**/demo/
doc/
debian/
setup/

# ==========================================
# 11. 排除翻譯檔（.po / .pot）
# ==========================================
**/i18n/
**/*.po
**/*.pot

# ==========================================
# 12. 追加排除（針對 Odoo 17 深度優化）
