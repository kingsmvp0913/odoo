<odoo>
    <data>
        <!-- tree -->
        <record id="view_idx_front_news_tree" model="ir.ui.view">
            <field name="name">idx.front.news.tree</field>
            <field name="model">idx.front.news</field>
            <field name="arch" type="xml">
                <tree string="訊息公告">
                    <field name="order_number"/>
                    <field name="sequence"/>
                    <field name="state"/>
                    <field name="type"/>
                    <field name="subject"/>
                    <field name="name"/>
                    <field name="working_date" avg="Avg of working day"/>
                    <field name="user_id" options="{'no_create_edit': True, 'no_create': True, 'no_open': True}"/>
                </tree>
            </field>
        </record>
        <!-- 相關人員tree -->
        <record id="view_idx_repair_related_tree" model="ir.ui.view">
            <field name="name">idx.repair.related.tree</field>
            <field name="model">idx.repair.related</field>
            <field name="arch" type="xml">
                <tree string="相關人員" editable="bottom">
                    <field name="repair_id"/>
                    <field name="user_id"/>
                </tree>
            </field>
        </record>


        <!-- form -->
        <record id="view_idx_front_news_form" model="ir.ui.view">
            <field name="name">idx.front.news.form</field>
            <field name="model">idx.front.news</field>
            <field name="arch" type="xml">  
                <form string="訊息公告">
                    <header>
                        <button name="%(idx_repair_manage_system.idx_create_news_wizard)d" string="建立公告" class="oe_highlight" type="action" context="{'default_post_date': current_date}"/>
                        <button name="action_state_post" string="發布" states="draft" type="object" class="oe_highlight"/>
                        <button name="action_state_invalid" string="失效" states="post" type="object" class="oe_highlight"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="open_related_lines"
                                    string="相關人員"
                                    class="oe_stat_button"
                                    type="object" icon="fa-th-list">
                            </button>
                        </div> 
                        <div>
                            <group>
                                <group>
                                    <field name="active"/>
                                    <field name="subject"/>
                                    <field name="type"/>
                                    <field name="name"/>
                                    <field name="user_id"/>
                                    <field name="user_email"/>
                                    <field name="user_phone"/>
                                </group>
                                <group>
                                    <field name="post_date"/>
                                    <field name="working_date"/>
                                    <field name="image" widget="image"/>
                                </group>
                                <notebook>
                                    <page string="公告諮詢">
                                        <group>
                                            <field name="news_more_ids">
                                                <tree>
                                                    <field name="connect_name"/>
                                                    <field name="connect_mail"/>
                                                    <field name="connect_phone"/>
                                                </tree>
                                            </field>
                                        </group>
                                    </page>
                                    <page string="備註">
                                        <group>
                                            <field name="note"/>
                                        </group>
                                    </page>
                                </notebook>
                            </group>
                        </div>
                    </sheet>                   
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- kanban -->
        <record id="idx_front_news_kanban" model="ir.ui.view">
            <field name="name">idx.front.news.kanban</field>
            <field name="model">idx.front.news</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" sample="1" default_group_by="state">
                    <field name="subject"/>
                    <field name="type"/>
                    <field name="name"/>
                    <field name="image"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                                <div class="o_kanban_image">
                                    <field name="image" widget="image" class="o_kanban_image_fill_left"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div class="oe_kanban_title">
                                        <field name="type" widget="badge"/>
                                    </div>
                                    <div>
                                        <field name="subject"/>
                                    </div>
                                    <div>
                                        <field name="name"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- search -->
        <record id="view_idx_front_news_search" model="ir.ui.view">
            <field name="name">idx.front.news.search</field>
            <field name="model">idx.front.news</field>
            <field name="arch" type="xml">
                <search string="訊息公告">
                    <!--欄位(多組)模糊搜尋-->
                    <field name="name" string="全部"
                        filter_domain="['|', ('subject', 'ilike', self),
                                            ('name', 'ilike', self)]"/>
                    <!--特定欄位搜尋-->
                    <field name="subject"/>
                    <field name="name"/>
                    <!--過濾器-->
                    <separator/>
                    <filter string="草稿" name="state_draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="發布" name="state_post" domain="[('state', '=', 'post')]"/>
                    <filter string="失效" name="state_validate" domain="[('state', '=', 'validate')]"/>
                    <!--群組-->
                    <group expand="1" string="Group By">
                        <filter string="狀態分組" name="group_state" context="{'group_by':'state'}"/>
                        <filter string="類別分組" name="group_type" context="{'group_by':'type'}"/>
                    </group>
                </search>
            </field>
        </record>


    </data>
</odoo>