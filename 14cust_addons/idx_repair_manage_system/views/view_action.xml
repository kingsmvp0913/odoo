<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>

        <record id="action_idx_front_news" model="ir.actions.act_window">
            <field name="name">訊息公告</field>
            <field name="res_model">idx.front.news</field>
            <field name="view_mode">tree,form,kanban</field>
            <field name="context">{'search_default_state_draft':1}</field>
        </record>

        <record id="action_idx_repair_related" model="ir.actions.act_window">
            <field name="name">相關人員</field>
            <field name="res_model">idx.repair.related</field>
            <field name="view_mode">tree</field>
        </record>

        <record model="ir.actions.act_window" id="service_setting_action">
            <field name="name">設定</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_mode">form</field>
            <field name="context">{'module' : 'om_setting'}</field>
        </record>

        <record id="idx_create_news_wizard" model="ir.actions.act_window">
            <field name="name">創建公告</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">idx.create.news.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="idx_create_news_wizard_form"/>
            <field name="target">new</field>
        </record>
        
    </data>
</odoo>