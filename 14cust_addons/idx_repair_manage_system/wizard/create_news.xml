<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <record id="idx_create_news_wizard_form" model="ir.ui.view">
       <field name="name">idx.create.news.wizard.form</field>
       <field name="model">idx.create.news.wizard</field>
       <field name="arch" type="xml">
           <form string="創建公告訊息">
               <group class="oe_title">
                   <field name="user_id"/>
                   <field name="post_date"/>
               </group>
               <footer>
                   <button name="create_news" string="創建" type="object" class="btn-primary"/>
                   <button string="取消" class="btn-secondary" special="cancel"/>
               </footer>
           </form>
       </field>
   </record>
</odoo>