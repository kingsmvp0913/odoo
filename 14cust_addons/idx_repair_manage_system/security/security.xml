<?xml version="1.0" ?>
<odoo>

    <record id="module_idx_front_system" model="ir.module.category">
        <field name="name">前台管理</field>
        <field name="description">IDX前台管理模組</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_front_user" model="res.groups">
        <field name="name">使用者</field>
        <field name="category_id" ref="module_idx_front_system"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_front_manager" model="res.groups">
        <field name="name">管理員</field>
        <field name="category_id" ref="module_idx_front_system"/>
        <field name="implied_ids" eval="[(4, ref('group_front_user'))]"/>
    </record>

    <record id="rule_front_user" model="ir.rule">
        <field name="name">前台管理：使用者只能看到自己的訊息公告</field>
        <field name="model_id" ref="model_idx_front_news"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4,ref('group_front_user'))]"/>
    </record>

    <record id="rule_front_manager" model="ir.rule">
        <field name="name">前台管理：管理員能看到全部的訊息公告</field>
        <field name="model_id" ref="model_idx_front_news"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4,ref('group_front_manager'))]"/>
    </record>
</odoo>