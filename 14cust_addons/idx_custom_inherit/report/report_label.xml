<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_sale_order_label">
        <t t-call="web.basic_layout">
            <t t-foreach="docs or []" t-as="o">

                <table style="width:100%; border-collapse: collapse;">
                    <tr>

                        <t t-set="col" t-value="0"/>

                        <t t-foreach="o.order_line or []" t-as="line">

                            <t t-if="col == 3">
                                <tr></tr>
                                <t t-set="col" t-value="0"/>
                            </t>

                            <td style="width:33%; padding:5px; vertical-align:top;">

                                <div style="height:200px; border:1px solid #000; padding:10px;">

                                    <!-- 名稱 -->
                                    <div style="font-size:14px; font-weight:bold;">
                                        <span t-esc="line.product_id.display_name"/>
                                    </div>

                                    <hr/>

                                    <!-- 單價 -->
                                    <div>
                                        單價：
                                        <span t-field="line.price_unit"
                                            t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </div>

                                    <hr/>

                                    <!-- 條碼 -->
                                    <div style="text-align:center;">

                                        <t t-if="line.product_id.barcode">
                                            <img t-att-src="'/report/barcode/Code128/%s' % line.product_id.barcode"
                                                style="width:100%; max-height:50px;"/>

                                            <div>
                                                <span t-esc="line.product_id.barcode"/>
                                            </div>
                                        </t>

                                        <t t-else="">
                                            <span style="color:red;">無條碼</span>
                                        </t>

                                    </div>

                                </div>

                            </td>

                            <t t-set="col" t-value="col + 1"/>

                        </t>

                    </tr>
                </table>

            </t>
        </t>
    </template>

</odoo>