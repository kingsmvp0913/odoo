<odoo>
    <data>
        <!-- tree -->
        <record id="view_idx_repair_order_tree" model="ir.ui.view">
            <field name="name">idx.repair.order.tree</field>
            <field name="model">idx.repair.order</field>
            <field name="arch" type="xml">
                <tree string="維修單">
                    <field name="name"/>
                    <field name="repair_date"/>
                    <field name="receipt_date" widget="remaining_day"/>
                    <field name="receipt_user_id" widget="many2one_avatar_user"/>
                    <field name="partner_id"/>
                    <field name="is_warranty" widget="boolean"/>
                </tree>
            </field>
        </record>


        <!-- form -->
        <record id="view_idx_repair_order_form" model="ir.ui.view">
            <field name="name">idx.repair.order.form</field>
            <field name="model">idx.repair.order</field>
            <field name="arch" type="xml">
                <form string="維修單號">
                    <sheet>
                        <div>
                            <group>
                                <group>
                                    <field name="repair_date"/>
                                    <field name="receipt_date"/>
                                    <field name="is_warranty"/>
                                </group>
                                <group>
                                    <field name="partner_id"/>
                                    <field name="receipt_user_id"/>
                                </group>
                            </group>
                            <notebook>
                                <page string="維修單明細">
                                    <field name="repair_line_ids" nolabel="1">
                                        <tree>
                                            <field name="name"/>
                                            <field name="qty"/>
                                            <field name="amount"/>
                                            <field name="total_amount"/>
                                        </tree>
                                        <form string="維修單明細">
                                            <group>
                                                <group>
                                                    <field name="name"/>
                                                    <field name="qty"/>
                                                </group>
                                                <group>
                                                    <field name="amount"/>
                                                    <field name="total_amount" readonly="1"/>
                                                </group>
                                            </group>
                                        </form>
                                    </field>

                                    <div style="text-align:right;font-size:20px;">維修合計：<field name="repair_amount" /></div>
                                </page>
                            </notebook>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- search -->
        <record id="view_idx_repair_order_search" model="ir.ui.view">
            <field name="name">idx.repair.order.search</field>
            <field name="model">idx.repair.order</field>
            <field name="arch" type="xml">
                <search string="維修單">
                    <field name="name"/>
                    <!--過濾器-->
                    <separator/>
                    <filter string="保固期間內" name="is_warranty_true" domain="[('is_warranty', '=', True)]"/>
                    <filter string="保固期間外" name="is_warranty_false" domain="[('is_warranty', '=', False)]"/>
                    <!--群組-->
                    <group expand="1" string="Group By">
                        <filter string="收件人員" name="group_type" context="{'group_by':'receipt_user_id'}"/>
                    </group>
                </search>
            </field>
        </record>

    </data>
</odoo>