<odoo>

    <record id="hr_overtime_statistics_view" model="ir.ui.view">
        <field name="name">hr.overtime.statistics.wizard.form</field>
        <field name="model">hr.overtime.statistics.wizard</field>
        <field name="arch" type="xml">
            <form string="加班統計表">
                <group>
                    <field name="date_start"/>
                    <field name="date_end"/>
                </group>
                <div>
                    註：報表資料依照日期區間重新產生
                </div>
                <footer>
                    <button string="產生" class="btn-primary" name="overtime_statistics_check" type="object"/>
                    <button string="關閉" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="hr_overtime_statistics_actions" model="ir.actions.act_window">
        <field name="name">加班統計表</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hr.overtime.statistics.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="hr_overtime_statistics_view"/>
        <field name="target">new</field>
    </record>

    <menuitem id="hr_overtime_submenu" name="加班"/>


    <menuitem id="menu_hr_overtime_statistics_top"
              name="加班統計表"
              parent="hr_overtime_submenu"
              sequence="3"
    />

    <menuitem
            id="menu_hr_overtime_statistics"
            name="加班統計表"
            parent="menu_hr_overtime_statistics_top"
            action="hr_overtime_statistics_actions"
            sequence="1"
    />

</odoo>
