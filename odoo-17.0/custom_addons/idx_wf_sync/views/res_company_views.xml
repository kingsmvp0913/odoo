<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="idx_view_company_form_inherit_wf_db" model="ir.ui.view">
        <field name="name">idx.res.company.form.inherit.wf.db</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="wf_db"/>
                <field name="wf_company"/>
            </xpath>
        </field>
    </record>
</odoo>
