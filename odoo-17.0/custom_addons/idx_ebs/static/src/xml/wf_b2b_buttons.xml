<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.ListView.Buttons" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class,'o_list_buttons')]" position="inside">
            <button
                t-if="state and state.canWfSync and props.context.tree_view_ref === 'website_sale.product_template_view_tree_website_sale'"
                type="button"
                class="btn btn-primary"
                t-on-click="onWfSyncClick">
                WF同步至B2B
            </button>
        </xpath>
    </t>

    <t t-inherit="web.KanbanView.Buttons" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class,'o_cp_buttons')]" position="inside">
            <button
                t-if="state and state.canWfSync and props.context.kanban_view_ref === 'website_sale.product_template_view_kanban_website_sale'"
                type="button"
                class="btn btn-primary"
                t-on-click="onWfSyncClick">
                WF同步至B2B
            </button>
        </xpath>
    </t>

    <t t-inherit="web.ListView.Buttons" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class,'o_list_buttons')]" position="inside">
            <button
                t-if="props.resModel === 'product.pricelist' and onWfSyncPricelistClick"
                type="button"
                class="btn btn-primary"
                t-on-click="onWfSyncPricelistClick">
                WF同步至B2B
            </button>
        </xpath>
    </t>
</templates>
