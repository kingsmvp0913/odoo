<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- 繼承購物車通知模板，無權限者隱藏價格欄位 -->
    <t t-inherit="website_sale.addToCartNotification" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('col-3') and hasclass('align-items-end')]" position="replace">
            <div class="col-3 d-flex flex-column align-items-end gap-1">
                <t t-if="line.line_price_total" t-out="getFormattedPrice(line)"/>
            </div>
        </xpath>
    </t>
</templates>