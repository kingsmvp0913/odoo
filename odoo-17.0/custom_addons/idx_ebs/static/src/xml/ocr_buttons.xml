<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web.ListView" t-inherit="web.ListView" t-inherit-mode="extension">
        <xpath expr="//t[@t-set-slot='control-panel-create-button']" position="inside">
            <button t-if="env.searchModel.resModel === 'idx.sale.order.ocr1'"
                    type="button" 
                    class="btn btn-primary" 
                    t-on-click="() => this.env.services.action.doAction({
                        type: 'ir.actions.client',
                        name: 'OCR辨識',
                        tag: 'idx_ebs.ocr_page1'
                    })">
                OCR辨識
            </button>
            <button t-if="env.searchModel.resModel === 'idx.sale.order.ocr2'"
                    type="button" 
                    class="btn btn-primary" 
                    t-on-click="() => this.env.services.action.doAction({
                        type: 'ir.actions.client',
                        name: 'OCR辨識',
                        tag: 'idx_ebs.ocr_page2'
                    })">
                OCR辨識
            </button>
        </xpath>
    </t>
    <t t-inherit="web.ListView.Buttons" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class,'o_list_buttons')]" position="inside">
            <button t-if="env.searchModel.resModel === 'idx.sale.order.ocr1'"
                type="button"
                class="btn btn-primary"
                t-on-click="MergeOrders1">
                合併成訂單
            </button>
            <button t-if="env.searchModel.resModel === 'idx.sale.order.ocr2'"
                type="button"
                class="btn btn-primary"
                t-on-click="MergeOrders2">
                合併成訂單
            </button>
        </xpath>
    </t>
</templates>