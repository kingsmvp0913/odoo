<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="idx_ebs.ocr_page2" owl="1">
        <div class="ocr-page-wrapper">
            <div class="container py-4">
                <div class="mb-4 text-center">
                    <h1 class="fw-bold mb-1">
                        凌越送檢單 － 小動物OCR辨識
                    </h1>
                </div>

                <!-- 功能卡片 -->
                <div class="row justify-content-center mb-4">

                    <!-- 上傳檔案 -->
                    <div class="col-md-5 mb-3">
                        <div class="card h-100 ocr-action-card text-center"
                             t-on-click="openFileDialog">
                            <div class="card-body">
                                <i class="fa fa-upload fa-2x mb-3 ocr-icon-upload"/>
                                <h5 class="fw-bold">上傳檔案</h5>
                                <small class="text-muted">支援多張圖片</small>
                            </div>
                        </div>
                    </div>

                    <!-- 相機掃描 -->
                    <div class="col-md-5 mb-3">
                        <div class="card h-100 ocr-action-card text-center"
                             t-on-click="startCamera">
                            <div class="card-body">
                                <i class="fa fa-camera fa-2x mb-3 ocr-icon-camera"/>
                                <h5 class="fw-bold">使用相機掃描</h5>
                                <small class="text-muted">即時拍照</small>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- 相機畫面 -->
                <div t-if="state.isCameraOn" class="text-center mb-4">
                    <video id="ocr_camera_preview"
                           autoplay="autoplay"
                           playsinline="playsinline"
                           class="border rounded w-100"
                           style="max-width: 420px;"/>

                    <div class="mt-3">
                        <button class="btn btn-primary me-2"
                                t-on-click="capturePhoto">
                            拍攝
                        </button>
                        <button class="btn btn-outline-secondary"
                                t-on-click="stopCamera">
                            關閉相機
                        </button>
                    </div>
                </div>

                <!-- 檔案清單 -->
                <div t-if="state.files.length" class="mb-4">
                    <div class="ocr-file-list-wrapper">
                        <h6 class="fw-bold mb-2">已上傳檔案</h6>
                        <ul class="list-group">
                            <t t-foreach="state.files" t-as="file" t-key="file.name">
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>
                                        <i class="fa fa-file-image-o me-2"/>
                                        <t t-esc="file.name"/>
                                    </span>
                                    <button class="btn btn-sm btn-outline-danger"
                                            t-on-click.stop="() => this.removeFile(file)">
                                        <i class="fa fa-trash"/>
                                    </button>
                                </li>
                            </t>
                        </ul>
                    </div>
                </div>

                <!-- 開始辨識 -->
                <div class="text-center">
                    <button class="btn btn-primary btn-lg px-5"
                            t-att-disabled="state.isProcessing or !state.files.length"
                            t-on-click="startRecognize">
                        <t t-if="!state.isProcessing">
                            開始辨識
                        </t>
                        <t t-if="state.isProcessing">
                            <i class="fa fa-spinner fa-spin me-2"/> 辨識中…
                        </t>
                    </button>
                </div>
            </div>
        </div>
    </t>
</templates>
