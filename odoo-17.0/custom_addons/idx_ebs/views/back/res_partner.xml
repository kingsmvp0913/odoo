<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="idx_res_partner_tree_inherit" model="ir.ui.view">
            <field name="name">idx.res.partner.tree.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='phone']" position="after">
                    <field name="full_name" optional="show"/>
                    <field name="partner_code" optional="show"/>
                    <field name="partner_class_ids" 
                        optional="show"
                        widget="many2many_tags" />
                    <field name="contact_address_inline" string="地址" optional="show"/>
                </xpath>
                <xpath expr="//field[@name='email']" position="after">
                    <field name="related_company_ids" 
                        optional="show"
                        widget="many2many_tags" />
                </xpath>
            </field>
        </record>
        <record id="idx_res_partner_template_form_multi_company" model="ir.ui.view">
            <field name="name">idx.res.partner.template.form.multi.company</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="priority">100</field>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('oe_title') and hasclass('mb24')]/h1" position="replace">
                    <h1 class="o_row">
                        <div class="o_col o_col-6">
                            <div class="o_row">
                                <label for="name" string="客戶簡稱"/>
                                <field name="name" required="1" placeholder="客戶簡稱"/>
                            </div>
                        </div>
                        <div class="o_col o_col-6">
                            <div class="o_row">
                                <label for="partner_code" string="客戶代號"/>
                                <field name="partner_code" 
                                    required="class_type == 'P'" 
                                    placeholder="客戶代號"/>
                            </div>
                        </div>
                    </h1>
                </xpath>
                <xpath expr="//span[@name='address_name']" position="before">
                    <field name="full_name" required="class_type == 'P'"/>
                </xpath>
                <xpath expr="//field[@name='function']" position="after">
                    <field name="related_company_ids" 
                        widget="many2many_tags" 
                        options="{'color_field': 'color', 'no_create': True,'no_create_edit': True}"/>
                </xpath>
                <xpath expr="//field[@name='vat']" position="attributes">
                    <attribute name="string">統一編號</attribute>
                </xpath>
                <xpath expr="//field[@name='vat']" position="after">
                    <field name="class_type" widget="selection_badge"/>
                    <field name="wf_tax_id" options="{'no_create': True,'no_create_edit': True}" required="not class_type == 'E'"/>
                    <field name="wf_tax_type"/>
                    <field name="odoo_tax_id"/>
                </xpath>
                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="partner_class_ids" 
                        widget="many2many_tags" 
                        options="{'color_field': 'color', 'no_create': True,'no_create_edit': True}"/>
                    <field name="available_download_ids" 
                        widget="many2many_checkboxes" 
                        options="{'no_create': True,'no_create_edit': True}"/>
                    <field name="user_ids" widget="many2many_tags"
                        context="{
                                'partner_portal': True,
                                'existing_partner_id': active_id,
                                'default_email': active_model.email
                            }"/>
                </xpath>
            </field>
        </record>
        <record id="idx_res_partner_view_search" model="ir.ui.view">
            <field name="name">idx.res.partner.search.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_res_partner_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="partner_code" string="客戶代號"/>
                </xpath>
                <xpath expr="//filter[@name='group_country']" position="after">
                    <filter string="標籤" 
                            name="group_by_category_id" 
                            context="{'group_by': 'category_id'}"/>
                    <filter string="客戶類別" 
                            name="group_by_partner_class" 
                            context="{'group_by': 'partner_class_ids'}"/>
                </xpath>
                <xpath expr="//filter[@name='inactive']" position="after">
                    <separator string="類型"/>
                    <filter string="類型:公司" name="filter_company" domain="[('class_type', '=', 'C')]"/>
                    <filter string="類型:客人" name="filter_customer" domain="[('class_type', '=', 'P')]"/>
                    <filter string="類型:員工" name="filter_employee" domain="[('class_type', '=', 'E')]"/>
                </xpath>
            </field>
        </record>
        <record id="idx_res_partner_hide_pricelist" model="ir.ui.view">
            <field name="name">idx.res.partner.hide.pricelist</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="product.view_partner_property_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='property_product_pricelist']" position="attributes">
                    <attribute name="readonly">1</attribute>
                    <attribute name="force_save">1</attribute>
                </xpath>
            </field>
        </record>
        <record id="idx_sale_action_partner_form" model="ir.actions.act_window">
            <field name="name">客戶</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="context">{'res_partner_search_mode': 'customer'}</field>
            <field name="domain">['|', '|', ('id', 'in', [1,3]), ('create_uid', '=', uid), ('user_id', '=', uid)]</field>
            <field name="search_view_id" ref="base.view_res_partner_filter"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                在通訊錄中建立聯繫人
              </p>
                <p>
                Odoo 可求助您追蹤與您的聯繫人相關的所有活動.
              </p>
            </field>
        </record>
        <record id="idx_sale_action_partner_form_view1" model="ir.actions.act_window.view">
            <field eval="0" name="sequence"/>
            <field name="view_mode">kanban</field>
            <field name="view_id" ref="base.res_partner_kanban_view"/>
            <field name="act_window_id" ref="idx_sale_action_partner_form"/>
        </record>
        <record id="idx_sale_action_partner_form_view2" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="base.view_partner_form"/>
            <field name="act_window_id" ref="idx_sale_action_partner_form"/>
        </record>
        <record id="idx_sale_action_partner_tree_view1" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="base.view_partner_tree"/>
            <field name="act_window_id" ref="idx_sale_action_partner_form"/>
        </record>
        <record id="idx_sale_res_partner_action_customer" model="ir.actions.act_window">
            <field name="name">客戶</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="domain">['|', '|', ('id', 'in', [1,3]), ('create_uid', '=', uid), ('user_id', '=', uid)]</field>
            <field name="context">{'search_default_customer': 1,'res_partner_search_mode': 'customer', 'default_is_company': True, 'default_customer_rank': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                在您的地址簿中建立一個聯繫人
              </p>
                <p>
                Odoo 求助您輕鬆跟進與客戶相關的所有活動.
              </p>
            </field>
        </record>
        <record id="idx_sale_action_partner_customer_form" model="ir.actions.act_window">
            <field name="name">客戶</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="domain">[]</field>
            <field name="domain">['|', '|', ('id', 'in', [1,3]), ('create_uid', '=', uid), ('user_id', '=', uid)]</field>
            <field name="context">{'res_partner_search_mode': 'customer', 'default_is_company': True}</field>
            <field name="filter" eval="True"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                在您的地址簿中建立一個聯繫人
              </p>
                <p>
                Odoo 求助您輕鬆跟進與客戶相關的所有活動.
              </p>
            </field>
        </record>
        <record id="idx_sale_action_partner_customer_form_view1" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">kanban</field>
            <field name="view_id" ref="base.res_partner_kanban_view"/>
            <field name="act_window_id" ref="idx_sale_action_partner_customer_form"/>
        </record>
        <record id="idx_sale_action_partner_customer_form_view2" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="base.view_partner_tree"/>
            <field name="act_window_id" ref="idx_sale_action_partner_customer_form"/>
        </record>
        <record id="idx_sale_action_partner_customer_form_view3" model="ir.actions.act_window.view">
            <field eval="3" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="base.view_partner_form"/>
            <field name="act_window_id" ref="idx_sale_action_partner_customer_form"/>
        </record>
    </data>
</odoo>