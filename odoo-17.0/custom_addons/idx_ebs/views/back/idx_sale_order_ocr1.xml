<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 人類醫學-OCR明細 search view -->
    <record id="idx_view_sale_order_ocr1_search" model="ir.ui.view">
        <field name="name">idx.sale.order.ocr1.search</field>
        <field name="model">idx.sale.order.ocr1</field>
        <field name="arch" type="xml">
            <search>
                <field name="order_id" string="全部"
                       filter_domain="['|','|','|','|','|','|',
                       ('order_id', 'ilike', self),
                       ('partner_id', 'ilike', self),
                       ('patient_name', 'ilike', self),
                       ('product_template_id', 'ilike', self),
                       ('detect_error', 'ilike', self),
                       ('send_date', 'ilike', self),
                       ('state', 'ilike', self)
                       ]"/>
                <filter name="filter_gender_male"
                    string="性別：男"
                    domain="[('gender', '=', 'male')]"/>
                <filter name="filter_gender_female"
                        string="性別：女"
                        domain="[('gender', '=', 'female')]"/>
                <filter name="filter_detect_error_has"
                        string="偵測錯誤"
                        domain="[('detect_error', '!=', False)]"/>
                <group expand="0" string="群組">
                    <filter name="group_partner"
                            string="客戶"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state"
                            string="訂單狀態"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_product"
                            string="檢測項目"
                            context="{'group_by': 'product_template_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <!-- 人類醫學-OCR明細 tree view -->
    <record id="idx_view_sale_order_ocr1_tree" model="ir.ui.view">
        <field name="name">idx.sale.order.ocr1.tree</field>
        <field name="model">idx.sale.order.ocr1</field>
        <field name="arch" type="xml">
            <tree editable="bottom" js_class="idx_view_sale_order_ocr1_tree">
                <field name="order_id" string="訂單號碼"/>
                <field name="image_file_name" column_invisible="1"/>
                <field name="image_file" string="圖片檔" widget="binary" filename="image_file_name" optional="show"/>
                <field name="partner_id" options="{'no_create': True, 'no_edit': True}"/>
                <field name="inspect_number"/>
                <field name="inspection_unit"/>
                <field name="patient_name" string="姓名"/>
                <field name="gender" string="性別"/>
                <field name="medical_no" string="病歷號碼"/>
                <field name="inspection_date" string="採檢日期" widget="date" options="{'format': 'yyyy:MM:dd'}"/>
                <field name="birth_date" string="出生年月日" widget="date" options="{'format': 'yyyy/MM/dd'}"/>
                <field name="sample_type" string="樣本種類"/>
                <field name="product_template_id" string="檢測項目" options="{'no_create': True, 'no_edit': True}" domain="[('category', '=', '0'), ('detailed_type', '=', 'service')]"/>
                <field name="note" string="備註"/>
                <field name="detect_error" string="偵測錯誤" widget="badge" decoration-danger="detect_error"/>
                <field name="create_date" string="明細建立日期"/>
                <field name="send_date" string="收件日期"/>
                <!--                <field name="category" string="類別"/>-->
                <field name="order_source" string="訂單來源"/>
                <field name="state" string="訂單狀態" widget="badge"/>
            </tree>
        </field>
    </record>
    <!-- 人類醫學-OCR明細 action -->
    <record id="idx_action_sale_order_ocr1" model="ir.actions.act_window">
        <field name="name">人類醫學-OCR明細</field>
        <field name="res_model">idx.sale.order.ocr1</field>
        <field name="view_mode">tree</field>
        <field name="context">{'search_default_filter_state_confirmed': 1 }</field>
    </record>
    <record id="idx_action_merge_order1" model="ir.actions.server">
        <field name="name">合併成訂單</field>
        <field name="model_id" ref="model_idx_sale_order_ocr1"/>
        <field name="binding_model_id" ref="model_idx_sale_order_ocr1"/>
        <field name="state">code</field>
        <field name="code">action = env["idx.sale.order.ocr1"].browse(env.context.get("active_ids", [])).action_merge_order1()</field>
    </record>
    <!-- 人類醫學-OCR明細 menuitem -->
    <menuitem
        id="idx_menu_sale_order_ocr1"
        name="人類醫學-OCR明細"
        parent="website_sale.menu_orders"
        action="idx_action_sale_order_ocr1"
        sequence="3"
    />
</odoo>
