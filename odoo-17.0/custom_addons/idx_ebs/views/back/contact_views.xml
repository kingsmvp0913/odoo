<odoo>

    <record id="contacts.menu_contacts" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('idx_ebs.group_back_sale'), ref('idx_ebs.group_back_doctor_sale_manager'),
        ref('idx_ebs.group_back_doctor_sale_manager'), ref('idx_ebs.group_back_international_sale_manager'), ref('idx_ebs.group_back_animal_sale_manager'),
        ref('idx_ebs.group_back_economic_animal_sale_manager'), ref('idx_ebs.group_back_document_management'), ref('idx_ebs.group_back_it')])]"/>
    </record>

    <record id="contacts.res_partner_menu_contacts" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('idx_ebs.group_back_doctor_sale_manager'),
        ref('idx_ebs.group_back_doctor_sale_manager'), ref('idx_ebs.group_back_international_sale_manager'), ref('idx_ebs.group_back_animal_sale_manager'),
        ref('idx_ebs.group_back_economic_animal_sale_manager'), ref('idx_ebs.group_back_document_management'), ref('idx_ebs.group_back_it')])]"/>
    </record>

    <record id="idx_sale_action_contacts" model="ir.actions.act_window">
        <field name="name">聯絡人</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,tree,form,activity</field>
        <field name="search_view_id" ref="base.view_res_partner_filter"/>
        <field name="context">{'default_is_company': True}</field>
        <field name="domain">['|', '|', ('id', 'in', [1,3]), ('create_uid', '=', uid), ('user_id', '=', uid)]</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            在通訊錄中建立聯繫人
          </p><p>
            Odoo 可求助您追蹤與您的聯繫人相關的所有活動.
          </p>
        </field>
    </record>

    <menuitem id="menu_idx_sale_res_partner_menu_contacts"
              action="idx_sale_action_contacts"
              parent="contacts.menu_contacts"
              groups="idx_ebs.group_back_sale"
              sequence="2"
    />

</odoo>
