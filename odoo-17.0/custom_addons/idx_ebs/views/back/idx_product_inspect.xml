<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ТфбжЕЌтѕЦtree view -->
    <record id="idx_view_product_inspect_tree" model="ir.ui.view">
        <field name="name">idx.product.inspect.tree</field>
        <field name="model">idx.product.inspect</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker" options="{'no_create': True}"/>
            </tree>
        </field>
    </record>

    <!-- ТфбжЕЌтѕЦ action -->
    <record id="idx_action_product_inspect" model="ir.actions.act_window">
        <field name="name">ТфбжЕЌтѕЦ</field>
        <field name="res_model">idx.product.inspect</field>
        <field name="view_mode">tree</field>
    </record>

    <!-- ТфбжЕЌтѕЦ menuitem -->
    <menuitem id="idx_menu_product_inspect"
        name="ТфбжЕЌтѕЦ"
        parent="website_sale.menu_catalog"
        action="idx_action_product_inspect"
        sequence="6"
    />

</odoo>