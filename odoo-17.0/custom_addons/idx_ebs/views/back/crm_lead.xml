<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 商機 form -->
    <record id="crm_lead_form_view_inherit" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="stock_lot_id" invisible="1"/>
                <field name="loyalty_card_id" invisible="1"/>
            </xpath>
            <xpath expr="//button[@name='action_view_sale_quotation']" position="attributes">
                <attribute name="invisible">stock_lot_id or type == 'lead'</attribute>
            </xpath>
            <xpath expr="//button[@name='action_schedule_meeting']" position="attributes">
                <attribute name="invisible">stock_lot_id</attribute>
            </xpath>
            <xpath expr="//group[@name='opportunity_partner']" position="attributes">
                <attribute name="invisible">stock_lot_id or type == 'lead'</attribute>
            </xpath>
            <xpath expr="//group[@name='opportunity_partner']" position="after">
                <group name="consumables_opportunity_partner" invisible="not stock_lot_id">
                    <field name="partner_id"
                        widget="res_partner_many2one"
                        string="客戶"
                        context="{'res_partner_search_mode': type == 'opportunity' and 'customer' or False,
                            'default_name': contact_name or partner_name,
                            'default_street': street,
                            'default_is_company': type == 'opportunity' and contact_name == False,
                            'default_company_name': type == 'opportunity' and partner_name,
                            'default_street2': street2,
                            'default_city': city,
                            'default_title': title,
                            'default_state_id': state_id,
                            'default_zip': zip,
                            'default_country_id': country_id,
                            'default_function': function,
                            'default_phone': phone,
                            'default_mobile': mobile,
                            'default_email': email_from,
                            'default_user_id': user_id,
                            'default_team_id': team_id,
                            'default_website': website,
                            'default_lang': lang_code,
                            'show_vat': True,
                        }"
                    />
                </group>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" name="action_open_card" type="object" icon="fa-ticket" 
                        invisible="stock_lot_id or not loyalty_card_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">優惠券</span>
                    </div>
                </button>
                <button class="oe_stat_button" name="action_open_product" type="object" icon="fa-ticket" 
                        invisible="not stock_lot_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">產品</span>
                    </div>
                </button>
                <button class="oe_stat_button" name="action_view_sale_orders" type="object" icon="fa-usd" invisible="not stock_lot_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">訂單</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>