<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="res_config_settings_view_form_inherit_fetch" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.fetch</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="idx_wf_sync.view_setting_form"/>
            <field name="arch" type="xml">
                <xpath expr="//app[@name='idx_wf_sync']/block[@name='idx_wf_sync_settings']" position="after">
                    <block title="OCR串接" name="idx_ocr_sync_block">
                        <setting id="enable_ocr_sync_setting" class="col-lg-12">
                            <field name="enable_sync_ocr"/>
                            <div class="card-body" invisible="not enable_sync_ocr">
                                <div class="row">
                                    <label for="ocr_url" class="col-lg-2 o_light_label" string="API 端點"/>
                                    <div class="col-lg-10">
                                        <field name="ocr_url" placeholder="https://p9.goodarc.com/webapi/api/Ocr/OcrCommon/ebs" class="w-100"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <label for="ocr_api_token" class="col-lg-2 o_light_label" string="API Token"/>
                                    <div class="col-lg-10">
                                        <field name="ocr_api_token" class="w-100" password="True"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <label for="ocr_key" class="col-lg-2 o_light_label" string="API Key"/>
                                    <div class="col-lg-10">
                                        <field name="ocr_key" class="w-100" password="True"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <label for="ocr_iv" class="col-lg-2 o_light_label" string="API IV"/>
                                    <div class="col-lg-10">
                                        <field name="ocr_iv" class="w-100" password="True"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <label for="encrypt_data" class="col-lg-2 o_light_label" string="Encrypt Data"/>
                                    <div class="col-lg-10">
                                        <field name="encrypt_data" class="w-100" password="True"/>
                                    </div>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="同步OneDrive" name="idx_onedrive_sync_block">
                        <setting id="enable_sync_onedrive_setting" class="col-lg-12">
                            <field name="enable_sync_onedrive"/>
                            <div class="card-body" invisible="not enable_sync_onedrive">
                                <div class="row">
                                    <label for="onedrive_email" class="col-lg-2 o_light_label" string="OneDrive帳號(Email)"/>
                                    <div class="col-lg-10">
                                        <field name="onedrive_email" placeholder="請輸入OneDrive帳號(Email)" class="w-100"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <label for="tenant_id" class="col-lg-2 o_light_label" string="Tenant ID"/>
                                    <div class="col-lg-10">
                                        <field name="tenant_id" class="w-100"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <label for="client_id" class="col-lg-2 o_light_label" string="Client ID"/>
                                    <div class="col-lg-10">
                                        <field name="client_id" class="w-100"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <label for="client_secret" class="col-lg-2 o_light_label" string="Client Secret"/>
                                    <div class="col-lg-10">
                                        <field name="client_secret" class="w-100" password="True"/>
                                    </div>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="FlipHTML5 電子書串接" name="idx_fliphtml5_sync_block">
                        <setting id="enable_sync_fliphtml5_setting" class="col-lg-12">
                            <field name="enable_sync_fliphtml5"/>
                            <div class="card-body" invisible="not enable_sync_fliphtml5">
                                <div class="row">
                                    <label for="fliphtml5_access_id" class="col-lg-2 o_light_label" string="Access ID"/>
                                    <div class="col-lg-10">
                                        <field name="fliphtml5_access_id" class="w-100"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <label for="fliphtml5_access_key" class="col-lg-2 o_light_label" string="Access Key"/>
                                    <div class="col-lg-10">
                                        <field name="fliphtml5_access_key" class="w-100"/>
                                    </div>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="黑貓串接" name="idx_tcat_sync_block">
                        <setting id="enable_tcat_sync_setting" class="col-lg-12">
                            <field name="enable_tcat"/>
                            <div class="card-body" invisible="not enable_tcat">
                                <div class="row">
                                    <label for="tcat_endpoint" class="col-lg-2 o_light_label" string="黑貓API端點"/>
                                    <div class="col-lg-10">
                                        <field name="tcat_endpoint" placeholder="測試:https://egs.suda.com.tw:8443, 正式:https://api.suda.com.tw、https://api.suda.net.tw:9443" class="w-100"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <label for="customer_id" class="col-lg-2 o_light_label" string="契約客戶代號"/>
                                    <div class="col-lg-10">
                                        <field name="customer_id" class="w-100"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <label for="customer_token" class="col-lg-2 o_light_label" string="契約客戶授權碼"/>
                                    <div class="col-lg-10">
                                        <field name="customer_token" class="w-100" password="True"/>
                                    </div>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="中華郵政串接" name="idx_post_sync_block">
                        <setting id="enable_post_sync_setting" class="col-lg-12">
                            <field name="enable_post"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>