<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 小動物-送檢單 search view -->
    <record id="idx_test_requisition2_search" model="ir.ui.view">
            <field name="name">idx.test.requisition2.search</field>
            <field name="model">idx.test.requisition2</field>
            <field name="arch" type="xml">
            <search>
                <field name="order_id" string="全部"
                       filter_domain="['|', '|', '|',
                       ('partner_id', 'ilike', self),
                       ('patient_name', 'ilike', self),
                       ('owner_name', 'ilike', self),
                       ('product_template_id', 'ilike', self)]"/>
                <filter name="filter_animal_type_dog"
                        string="物種：犬"
                        domain="[('animal_type', '=', 'dog')]"/>
                <filter name="filter_animal_type_cat"
                        string="物種：貓"
                        domain="[('animal_type', '=', 'cat')]"/>
                <filter name="filter_gender_male"
                        string="性別：公"
                        domain="[('gender', '=', 'male')]"/>
                <filter name="filter_gender_female"
                        string="性別：母"
                        domain="[('gender', '=', 'female')]"/>
                <filter name="filter_neutered_yes"
                        string="絕育：是"
                        domain="[('neutered', '=', True)]"/>
                <filter name="filter_neutered_no"
                        string="絕育：否"
                        domain="[('neutered', '=', False)]"/>
                <group expand="0" string="群組">
                    <filter name="group_partner"
                            string="送檢單位"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_product"
                            string="檢測項目"
                            context="{'group_by': 'product_template_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- 小動物-送檢單 tree view -->
    <record id="idx_test_requisition2_tree" model="ir.ui.view">
        <field name="name">idx.test.requisition2.tree</field>
        <field name="model">idx.test.requisition2</field>
        <field name="arch" type="xml">
            <tree string="小動物-送檢單" create="false" delete="false" duplicate="false">
                <field name="product_template_id" string="檢測項目" options="{'no_create': True, 'no_edit': True}"/>
                <field name="partner_id" string="送檢醫院" options="{'no_create': True, 'no_edit': True}"/>
                <field name="patient_name" string="病患名稱"/>
                <field name="owner_name" string="飼主姓名"/>
                <field name="animal_type" string="物種"/>
                <field name="collect_date" string="採血日期" widget="date" options="{'format': 'yyyy/MM/dd'}"/>
                <field name="gender" string="性別"/>
                <field name="neutered" string="絕育"/>
            </tree>
        </field>
    </record>

    <!-- 小動物-送檢單 form view -->
    <record id="idx_test_requisition2_form" model="ir.ui.view">
        <field name="name">idx.test.requisition2.form</field>
        <field name="model">idx.test.requisition2</field>
        <field name="arch" type="xml">
            <form string="小動物-送檢單" create="false" duplicate="false">
                <sheet>
                    <group>
                        <group string="檢測資訊">
                            <field name="product_template_id" string="檢測項目" readonly="1"/>
                            <field name="internal_note" string="檢測備註" readonly="1"/>
                        </group>
                        <group string="送檢資訊">
                            <field name="partner_id" string="送檢醫院" readonly="1"/>
                            <field name="state" invisible="1"/>
                            <field name="doctor_name" string="送檢醫師" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                            <field name="partner_address" string="醫院地址" readonly="1"/>
                            <field name="partner_email" string="Email" readonly="1"/>
                            <field name="partner_phone" string="電話" readonly="1"/>
                        </group>
                        <group string="病患資料">
                            <field name="patient_name" string="病患名稱" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                            <field name="owner_name" string="飼主姓名" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                            <field name="animal_type" string="物種" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                            <field name="breed" string="品系" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                            <field name="weight" string="體重(kg)" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                            <field name="gender" string="性別" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                            <field name="neutered" string="是否絕育" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                            <field name="age" string="年齡(yo)" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                    </group>
                    <separator string="Patient History"/>
                    <group>
                        <group>
                            <field name="has_other_animals" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                        <group>
                            <field name="other_animals_count" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="flea_history" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="environment_changed" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                        <group>
                            <field name="environment_change_desc" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="first_onset_age" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                            <field name="recurrent_years" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                        <group>
                            <field name="recurrent_duration" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="symptom_type" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="long_term_attack" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="skin_symptom_ids" widget="many2many_tags" options="{'no_create': True, 'no_edit': True}" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="parasite_type" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                        <group>
                            <field name="secondary_infection" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                    </group>
                    <group>
                        <field name="symptom_period" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                    </group>
                    <group>
                        <group>
                            <field name="severe_season" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                        <group>
                            <field name="severe_months" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                    </group>
                    <separator string="六個月內用藥史"/>
                    <div class="o_row">
                        <div class="o_col o_form_label">項目</div>
                        <div class="o_col o_form_label">藥物成分名、劑量和給予途徑</div>
                        <div class="o_col o_form_label">最後一次給藥時間</div>
                        <div class="o_col o_form_label">改善/無感/惡化</div>
                    </div>
                    <div class="o_row">
                        <div class="o_col o_form_label">Corticosteroids</div>
                        <field name="corticosteroids_note" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        <field name="corticosteroids_last_date" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        <field name="corticosteroids_effect" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                    </div>
                    <div class="o_row">
                        <div class="o_col o_form_label">Antihistamine</div>
                        <field name="antihistamine_note" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        <field name="antihistamine_last_date" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        <field name="antihistamine_effect" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                    </div>
                    <div class="o_row">
                        <div class="o_col o_form_label">Antibiotics</div>
                        <field name="antibiotics_note" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        <field name="antibiotics_last_date" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        <field name="antibiotics_effect" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                    </div>
                    <div class="o_row">
                        <div class="o_col o_form_label">Antifungal</div>
                        <field name="antifungal_note" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        <field name="antifungal_last_date" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        <field name="antifungal_effect" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                    </div>
                    <div class="o_row">
                        <div class="o_col o_form_label">Others</div>
                        <field name="other_med_note" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        <field name="other_med_last_date" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        <field name="other_med_effect" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 小動物-送檢單 action -->
    <record id="idx_action_test_requisition2" model="ir.actions.act_window">
        <field name="name">小動物-送檢單</field>
        <field name="res_model">idx.test.requisition2</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <!-- 小動物-送檢單 menuitem -->
    <menuitem
        id="idx_menu_test_requisition2"
        name="小動物-送檢單"
        parent="website_sale.menu_orders"
        action="idx_action_test_requisition2"
        sequence="6"
    />
</odoo>
