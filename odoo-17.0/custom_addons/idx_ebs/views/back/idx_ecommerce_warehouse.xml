<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 電子商務_倉庫 tree view -->
    <record id="idx_view_ecommerce_warehouse_tree" model="ir.ui.view">
        <field name="name">idx.ecommerce.warehouse.tree</field>
        <field name="model">idx.ecommerce.warehouse</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <!-- 電子商務_倉庫 action -->
    <record id="idx_action_ecommerce_warehouse" model="ir.actions.act_window">
        <field name="name">電子商務倉庫</field>
        <field name="res_model">idx.ecommerce.warehouse</field>
        <field name="view_mode">tree</field>
    </record>

    <!-- 電子商務_倉庫 menuitem -->
    <menuitem
        id="idx_menu_ecommerce_warehouse"
        name="倉庫"
        parent="website_sale.menu_ecommerce_settings"
        action="idx_action_ecommerce_warehouse"
        sequence="110"
    />

</odoo>
