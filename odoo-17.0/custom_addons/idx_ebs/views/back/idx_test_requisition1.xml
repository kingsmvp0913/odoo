<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 人類醫學-送檢單 search view -->
    <record id="idx_test_requisition1_search" model="ir.ui.view">
            <field name="name">idx.test.requisition1.search</field>
            <field name="model">idx.test.requisition1</field>
            <field name="arch" type="xml">
            <search>
                <field name="order_id" string="全部"
                       filter_domain="['|', '|',
                       ('partner_id', 'ilike', self),
                       ('patient_name', 'ilike', self),
                       ('product_template_id', 'ilike', self)]"/>
                <filter name="filter_gender_male"
                        string="性別：男"
                        domain="[('gender', '=', 'male')]"/>
                <filter name="filter_gender_female"
                        string="性別：女"
                        domain="[('gender', '=', 'female')]"/>
                <group expand="0" string="群組">
                    <filter name="group_partner"
                            string="客戶"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_product"
                            string="檢測項目"
                            context="{'group_by': 'product_template_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- 人類醫學-送檢單 tree view -->
    <record id="idx_test_requisition1_tree" model="ir.ui.view">
        <field name="name">idx.test.requisition1.tree</field>
        <field name="model">idx.test.requisition1</field>
        <field name="arch" type="xml">
            <tree string="人類醫學-送檢單" create="false" delete="false" duplicate="false">
                <field name="product_template_id" string="檢測項目" options="{'no_create': True, 'no_edit': True}"/>
                <field name="partner_id" options="{'no_create': True, 'no_edit': True}"/>
                <field name="inspection_unit"/>
                <field name="patient_name"/>
                <field name="gender"/>
                <field name="medical_no"/>
                <field name="birth_date" widget="date" options="{'format': 'yyyy/MM/dd'}"/>
                <field name="sample_type"/>
                <field name="note" string="備註"/>
            </tree>
        </field>
    </record>

    <!-- 人類醫學-送檢單 form view -->
    <record id="idx_test_requisition1_form" model="ir.ui.view">
        <field name="name">idx.test.requisition1.form</field>
        <field name="model">idx.test.requisition1</field>
        <field name="arch" type="xml">
            <form string="人類醫學-送檢單" create="false" delete="false" duplicate="false">
                <sheet>
                    <group>
                        <group string="檢測資訊" col="2">
                            <field name="product_template_id" string="檢測項目" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="state" invisible="1"/>
                            <field name="inspection_unit" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        </group>
                        <group string="病患資料" col="2">
                            <field name="patient_name" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                            <field name="gender" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                            <field name="medical_no" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                            <field name="birth_date"
                                   widget="date"
                                   options="{'format': 'yyyy/MM/dd'}"
                                   readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"
                            />
                        </group>
                    </group>
                    <group string="檢體資訊" col="2">
                        <field name="sample_type" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                        <field name="note" string="備註" readonly="state in ['wf_confirm', 'inspected', 'reported', 'sent_report']"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 人類醫學-送檢單 action -->
    <record id="idx_action_test_requisition1" model="ir.actions.act_window">
        <field name="name">人類醫學-送檢單</field>
        <field name="res_model">idx.test.requisition1</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <!-- 人類醫學-送檢單 menuitem -->
    <menuitem
        id="idx_menu_test_requisition1"
        name="人類醫學-送檢單"
        parent="website_sale.menu_orders"
        action="idx_action_test_requisition1"
        sequence="5"
        groups="idx_ebs.group_back_inspect_ocr1,idx_ebs.group_back_document_management,idx_ebs.group_back_it"
    />

</odoo>
