<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 電子商務_產品 search -->
    <record id="idx_product_template_search" model="ir.ui.view">
        <field name="name">product.template.search.website.extend</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="website_sale.product_template_search_view_website"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="default_code" string="全部"
                       filter_domain="[
                       '|','|',
                       ('default_code', 'ilike', self),
                       ('catalog_number', 'ilike', self),
                       ('specification', 'ilike', self)
                   ]"/>
                <field name="avg_recommended_qty" string="平均建議申請量"/>
                <field name="description" string="內部備註"/>
                <filter name="wf_synced" string="已同步WF"
                        domain="[('wf_sync_time', '>', 0)]"/>
                <filter name="wf_unsynced" string="未同步WF"
                        domain="[('wf_sync_time', '=', 0)]"/>
                <separator/>
                <filter name="wf_stock_management_y" string="庫存管理"
                        domain="[('wf_stock_management', '=', 'Y')]"/>
                <filter name="wf_stock_management_n" string="無庫存管理"
                        domain="[('wf_stock_management', '=', 'N')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_category"
                            string="檢測單類別"
                            context="{'group_by': 'category'}"/>
                    <filter name="group_by_business_category_id"
                            string="業務類別"
                            context="{'group_by': 'business_category_id'}"/>
                    <filter name="group_by_product_category_id"
                            string="商品類別"
                            context="{'group_by': 'product_category_id'}"/>
                    <filter name="group_by_wf_sync_dt"
                            string="WF同步時間"
                            context="{'group_by': 'wf_sync_datetime'}"/>
                    <filter name="group_by_wf_sync_time"
                            string="WF同步次數"
                            context="{'group_by': 'wf_sync_time'}"/>
                    <filter name="group_by_wf_warehouse_id"
                            string="WF主要庫別"
                            context="{'group_by': 'wf_warehouse_id'}"/>
                </group>
            </xpath>
        </field>
    </record>
    <!-- 電子商務_產品 formview -->
    <record id="idx_product_template_only_form_view" model="ir.ui.view">
        <field name="name">idx.product.template.only.form.view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_sync_wf" type="object" string="WF同步至B2B" class="btn-primary" groups="idx_ebs.group_back_it,idx_ebs.group_back_document_management"/>
            </xpath>
            <xpath expr="//field[@name='detailed_type']" position="after">
                <field name="is_fee" string="是否為費用" invisible="detailed_type !='service'"/>
            </xpath>
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="category" string="檢測單類別" required="detailed_type =='service'"/>
                <field name="business_category_id" string="業務類別" options="{'no_create': True, 'no_edit': True}"/>
                <field name="product_category_id" string="商品類別" options="{'no_create': True, 'no_edit': True}" domain="[('name', '!=', '耗材')]"/>
                <field name="product_desc" string="產品說明"/>
            </xpath>
            <xpath expr="//field[@name='categ_id']/following-sibling::field[@name='default_code']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
    <!-- 電子商務_產品 formview -->
    <record id="idx_product_template_form_view" model="ir.ui.view">
        <field name="name">idx.product.template.form.view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="create">false</attribute>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]" position="replace">
                <div class="oe_title">
                    <field name="priority" widget="priority" class="me-3"/>
                    <group>
                        <group>
                            <field name="default_code" string="品號" readonly="1"/>
                        </group>
                        <group>
                            <field name="catalog_number" string="貨號" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="name" string="品名" readonly="1"/>
                        </group>
                        <group>
                            <field name="specification" string="規格" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="new_product_approval_date" string="新品核准日期" readonly="1"/>
                        </group>
                    </group>
                </div>
            </xpath>
            <xpath expr="//group[@name='group_general']/field[@name='uom_id']" position="attributes">
                <attribute name="string">單位</attribute>
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//group[@name='group_general']/field[@name='uom_po_id']" position="attributes">
                <attribute name="string">採購單位</attribute>
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//group[@name='group_general']/field[@name='uom_po_id']" position="after">
                <field name="uom_so_id" string="銷售單位" readonly="1"/>
                <field name="avg_recommended_qty" string="平均建議申請量"/>
                <field name="effective_date" string="生效日期" readonly="1"/>
                <field name="expiry_date" string="失效日期" readonly="1"/>
            </xpath>
            <xpath expr="//group[@name='group_standard_price']//field[@name='list_price']" position="attributes">
                <attribute name="string">報價</attribute>
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//group[@name='group_standard_price']/div[@name='pricing']" position="after">
                <label for="sale_price" string="定價"/>
                <div class="o_row">
                    <field name="sale_price" class="oe_inline" widget="monetary"
                        options="{'currency_field': 'currency_id'}"/>
                </div>
            </xpath>
            <xpath expr="//field[@name='taxes_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- <xpath expr="//field[@name='product_category_id']" position="attributes">
                <attribute name="domain">[('name', '!=', '耗材')]</attribute>
            </xpath> -->
            <xpath expr="//group[@name='group_standard_price']/field[@name='categ_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='sale_delay']" position="attributes">
                <attribute name="string">送達前置時間</attribute>
            </xpath>
            <xpath expr="//page[@name='inventory']" position="after">
                <page string="WF同步資訊" name="wf_sync_info_page">
                    <group>
                        <group>
                            <field name="wf_sync_time" readonly="1" force_save="1"/>
                            <field name="wf_sync_datetime" readonly="1" force_save="1"/>
                            <field name="wf_sync_user_id" readonly="1" force_save="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
            <xpath expr="//page[@name='invoicing']//group[@name='accounting']" position="inside">
                <field name="categ_id" string="會計" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='use_expiration_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//group[@name='group_lots_and_weight']" position="before">
                <group string="WF設定" name="wf_setting_group">
                    <field name="wf_warehouse_id" readonly="1"/>
                    <field name="wf_stock_management" readonly="1"/>
                    <field name="wf_lot_management" readonly="1"/>
                    <field name="wf_inspection_type" readonly="1"/>
                    <field name="wf_valid_days" readonly="1"/>
                    <field name="wf_reinspection_days" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
    <!-- 電子商務_產品 treeview -->
    <record id="idx_product_template_view_tree_website_sale" model="ir.ui.view">
        <field name="name">idx.product.template.view.tree.website_sale</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="website_sale.product_template_view_tree_website_sale"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="create">false</attribute>
            </xpath>
            <xpath expr="//field[@name='default_code']" position="attributes">
                <attribute name="string">品號</attribute>
            </xpath>
            <xpath expr="//field[@name='public_categ_ids']" position="replace">
                <field name="category" string="檢測單類別" widget="selection" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='is_published']" position="after">
                <field name="business_category_id" string="業務類別" optional="show"/>
                <field name="product_category_id" string="商品類別" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='standard_price']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='product_tag_ids']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='list_price']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='detailed_type']" position="before">
                <field name="sale_price" string="定價" optional="show"/>
                <field name="avg_recommended_qty" string="平均建議申請量" optional="show"/>
            </xpath>
        </field>
    </record>
    <record id="idx_product_template_consumable_search" model="ir.ui.view">
        <field name="name">product.template.consumable.search.website.extend</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="idx_ebs.idx_product_template_search"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='wf_synced']" position="replace">
            </xpath>
            <xpath expr="//filter[@name='wf_unsynced']" position="replace">
            </xpath>
            <xpath expr="//filter[@name='group_by_wf_sync_dt']" position="replace">
            </xpath>
            <xpath expr="//filter[@name='group_by_wf_sync_time']" position="replace">
            </xpath>
            <xpath expr="//filter[@name='group_by_wf_warehouse_id']" position="replace">
            </xpath>
        </field>
    </record>
    <!-- 電子商務_產品-耗材 formview -->
    <record id="idx_product_template_consumable_form_view" model="ir.ui.view">
        <field name="name">idx.product.template.consumable.form.view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="idx_ebs.idx_product_template_form_view"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_open_label_layout']" position="after">
                <button name="%(action_idx_replenish_consumable_quantity)d" string="補充耗材數量" type="action" class="btn-primary" context="{'default_product_id': product_variant_id}"/>
            </xpath>
            <xpath expr="//form" position="attributes">
                <attribute name="create">true</attribute>
            </xpath>
            <xpath expr="//field[@name='default_code']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
            <xpath expr="//field[@name='catalog_number']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
            <xpath expr="//field[@name='specification']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
            <xpath expr="//field[@name='new_product_approval_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='effective_date']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
            <xpath expr="//field[@name='expiry_date']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
            <xpath expr="//field[@name='tracking']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
            <xpath expr="//page[@name='wf_sync_info_page']" position="replace">
            </xpath>
            <xpath expr="//group[@name='wf_setting_group']" position="replace">
            </xpath>
            <xpath expr="//page[@name='general_information']" position="after">
                <page string="批次/序號" name="page_lot_info">
                    <field name="lot_line_ids" context="{'default_product_tmpl_id': id}">
                        <tree editable="bottom">
                            <field name="product_id" column_invisible="1"/>
                            <field name="product_tmpl_id" column_invisible="1"/>
                            <field name="lot_id" string="批次/序號" required="1" options="{'no_create_edit': True, 'always_reload': True}" domain="[('product_id', '=', product_id)]" context="{'default_expiration_date': current_date, 'default_product_id': product_id, 'form_view_ref': 'idx_ebs.view_production_lot_custom_form'}"/>
                            <field name="expiration_date" string="有效日期"/>
                            <field name="is_alert" column_invisible="1"/>
                            <field name="alert_date" readonly="1" string="警示日期" decoration-danger="is_alert"/>
                            <field name="is_valid_days_remaining" column_invisible="1"/>
                            <field name="valid_days_remaining" string="剩餘有效天數" decoration-danger="is_valid_days_remaining"/>
                            <field name="product_qty" string="在庫數量"/>
                        </tree>
                    </field>
                </page>
            </xpath>
            <xpath expr="//page[@name='inventory']" position="replace">
            </xpath>
        </field>
    </record>
    <!-- 產品主檔的批號form -->
    <record id="view_production_lot_custom_form" model="ir.ui.view">
        <field name="name">view.production.lot.custom.form</field>
        <field name="model">stock.lot</field>
        <field name="arch" type="xml">
            <form string="批次/序號">
                <sheet>
                    <group>
                        <field name="product_id" readonly="1" force_save="1"/>
                        <field name="name"/>
                        <field name="expiration_date" required="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- 電子商務_產品_耗材 treeview -->
    <record id="idx_product_template_consumable_tree_view" model="ir.ui.view">
        <field name="name">idx.product.template.consumable.tree.view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="idx_ebs.idx_product_template_view_tree_website_sale"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="create">true</attribute>
            </xpath>
            <xpath expr="//field[@name='category']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='business_category_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='avg_recommended_qty']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
        </field>
    </record>
    <!-- 電子商務_產品-耗材 kanbanview -->
    <record id="idx_product_template_consumable_kanban_view" model="ir.ui.view">
        <field name="name">idx.product.template.consumable.kanban.view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="website_sale.product_template_view_kanban_website_sale"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="create">true</attribute>
            </xpath>
        </field>
    </record>
    <!-- 電子商務_產品 treeview 增加WF同步B2B按鈕-->
    <record id="idx_product_template_tree_wf" model="ir.ui.view">
        <field name="name">product.template.tree.wf</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="js_class">idx_product_template_list_wf</attribute>
                <attribute name="create">false</attribute>
            </xpath>
        </field>
    </record>
    <!-- 會計_產品 treeview 增加WF同步B2B按鈕-->
    <record id="idx_account_template_tree_wf" model="ir.ui.view">
        <field name="name">product.template.tree.wf2</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="account.product_template_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="js_class">idx_product_template_list_wf</attribute>
                <attribute name="create">false</attribute>
            </xpath>
        </field>
    </record>
    <!-- 電子商務_產品 kabanview 增加WF同步B2B按鈕-->
    <record id="idx_product_template_kanban_wf" model="ir.ui.view">
        <field name="name">product.template.kanban.wf</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_kanban_view"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="js_class">idx_product_template_kanban_wf</attribute>
                <attribute name="create">false</attribute>
            </xpath>
        </field>
    </record>
    <!-- 價格表 tree -->
    <record id="idx_product_pricelist_tree_view_inherit" model="ir.ui.view">
        <field name="name">idx.product.pricelist.tree.view.inherit</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="js_class">idx_product_pricelist_list_wf</attribute>
            </xpath>
            <xpath expr="//field[@name='discount_policy']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='currency_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='selectable']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
        </field>
    </record>
    <!-- 價格表 form -->
    <record id="idx_product_pricelist_form_view_inherit" model="ir.ui.view">
        <field name="name">idx.product.pricelist.form.view.inherit</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet" position="before">
                <header>
                    <button name="action_sync_wf" type="object" string="WF同步至B2B" class="btn-primary"/>
                </header>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]" position="replace">
            </xpath>
            <xpath expr="//group[@name='pricelist_settings']" position="replace">
                <!-- 價格表單頭 -->
                <group name="pricelist_settings">
                    <field name="name" placeholder="e.g. USD Retailers" style="font-size:1.75rem; color: #212529; margin-top: 0; margin-bottom: 8px; font-weight: 500; line-height: 1.2;"/>
                    <field name="currency_id" invisible="1" groups="base.group_multi_currency"/>
                    <field name="active" invisible="1"/>
                    <field name="wf_tax_id"/>
                    <field name="wf_tax_type"/>
                    <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                </group>
                <group>
                    <field name="partner_full_name"/>
                    <field name="partner_code"/>
                    <field name="partner_id" options="{'no_create': True}"/>
                </group>
            </xpath>
            <!-- 價格表單身 -->
            <xpath expr="//field[@name='item_ids']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </xpath>
            <xpath expr="//field[@name='min_quantity']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='date_start']" position="before">
                <field name="create_date" string="建立日" optional="hide"/>
            </xpath>
            <xpath expr="//field[@name='product_tmpl_id']" position="before">
                <field name="wf_slip" optional="show"/>
                <field name="wf_number" optional="show"/>
                <field name="wf_serial" optional="show"/>
                <field name="wf_doc_date" optional="show"/>
                <field name="wf_quote_date" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='product_tmpl_id']" position="after">
                <field name="default_code" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='fixed_price']" position="before">
                <field name="wf_price" string="單價"/>
                <field name="inc_tax_price"/>
            </xpath>
            <xpath expr="//field[@name='fixed_price']" position="attributes">
                <attribute name="string">未稅單價</attribute>
            </xpath>
            <xpath expr="//field[@name='date_start']" position="attributes">
                <attribute name="string">生效日</attribute>
            </xpath>
            <xpath expr="//field[@name='date_end']" position="attributes">
                <attribute name="string">失效日</attribute>
            </xpath>
            <xpath expr="//page[@name='pricelist_config']//group[@name='pricelist_discounts']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='pricelist_rules']" position="after">
                <page string="耗材產品">
                    <field name="consumables" options="{'no_create': True}">
                        <tree editable="bottom">
                            <field name="name"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
    <record id="idx_product_pricelist_form_view_inherit_website_sale" model="ir.ui.view">
        <field name="name">idx.product.pricelist.form.view.inherit.website.sale</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="website_sale.website_sale_pricelist_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='selectable']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
    <!-- 價格表 search -->
    <record id="idx_product_pricelist_search_view_inherit" model="ir.ui.view">
        <field name="name">idx.product.pricelist.search.view.inherit</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="item_ids" string="WF報價單單別" filter_domain="[('item_ids.wf_slip', 'ilike', self)]"/>
                <field name="item_ids" string="WF報價單單號" filter_domain="[('item_ids.wf_number', 'ilike', self)]"/>
                <field name="item_ids" string="WF單據日期" filter_domain="[('item_ids.wf_doc_date', 'ilike', self)]"/>
                <field name="item_ids" string="WF報價日期" filter_domain="[('item_ids.wf_quote_date', 'ilike', self)]"/>
