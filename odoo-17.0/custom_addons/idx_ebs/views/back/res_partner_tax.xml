<odoo>
    <record id="view_partner_tax_tree" model="ir.ui.view">
        <field name="name">res.partner.tax.tree</field>
        <field name="model">res.partner.tax</field>
        <field name="arch" type="xml">
            <tree string="客戶稅別列表" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="rate" widget="percentage"/>
                <field name="invoice_count"/>
                <field name="invoice_name" readonly="1"/>
                <field name="tax_type"/>
                <field name="remark"/>
                <field name="odoo_tax_id"/>
            </tree>
        </field>
    </record>
    <record id="view_partner_tax_form_readonly" model="ir.ui.view">
        <field name="name">res.partner.tax.form.readonly</field>
        <field name="model">res.partner.tax</field>
        <field name="arch" type="xml">
            <form string="客戶稅別" edit="false" create="false">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="rate"/>
                        <field name="tax_type"/>
                        <field name="odoo_tax_id" options="{'no_open': True}"/>
                        <field name="remark"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_partner_tax" model="ir.actions.act_window">
        <field name="name">WF稅別碼</field>
        <field name="res_model">res.partner.tax</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                點擊新增，在列表底部直接建立您的第一個稅別設定。
            </p>
        </field>
    </record>
    <menuitem id="menu_partner_tax_setting" 
                  name="客戶稅別" 
                  action="action_partner_tax" 
                  parent="contacts.res_partner_menu_config" 
                  sequence="3"/>
</odoo>