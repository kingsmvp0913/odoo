<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Search View -->
    <record id="idx_survey_survey_view_search_inherit" model="ir.ui.view">
    <field name="name">idx.survey.survey.search.inherit</field>
    <field name="model">survey.survey</field>
    <field name="inherit_id" ref="survey.survey_survey_view_search"/>
    <field name="arch" type="xml">
        <xpath expr="//search" position="replace">
            <search string="Survey">
                <field name="title"
                       string="全部"
                       filter_domain="[
                           '|','|','|','|',
                           ('title', 'ilike', self),
                           ('partner_id', 'ilike', self),
                           ('partner_code', 'ilike', self),
                           ('product_template_id', 'ilike', self),
                           ('user_id', 'ilike', self)
                       ]"/>
            </search>
            </xpath>
        </field>
    </record>

    <!-- Tree View -->
    <record id="idx_survey_survey_view_tree_inherit" model="ir.ui.view">
        <field name="name">idx.survey.survey.view.tree.inherit</field>
        <field name="model">survey.survey</field>
        <field name="inherit_id" ref="survey.survey_survey_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="replace">
                <tree string="QRCode 問卷">
                    <field name="title" string="名稱"/>
                    <field name="partner_id"/>
                    <field name="partner_code"/>
                    <field name="product_template_id"/>
                    <field name="user_id"/>
                </tree>
            </xpath>
        </field>
    </record>

    <!-- FORM View -->
    <record id="idx_survey_survey_view_form_inherit" model="ir.ui.view">
        <field name="name">idx.survey.survey.view.form.inherit</field>
        <field name="model">survey.survey</field>
        <field name="inherit_id" ref="survey.survey_survey_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_regenerate_qrcode" 
                        string="重新生成 QR Code" 
                        type="object" 
                        class="btn-secondary"/>
            </xpath>
            <xpath expr="//button[@name='action_result_survey']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_survey_user_input']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_start_session']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_archive']" position="attributes">
                <attribute name="string">表單失效</attribute>
            </xpath>
            <xpath expr="//field[@name='survey_type']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='background_image']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//group[@name='scoring']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//div[@class='oe_title']" position="before">
                <field name="category" required="1" widget="radio" options="{'horizontal': true}"/>
                <field name="qrcode_image" widget="image" class="oe_avatar"/>
            </xpath>
            <xpath expr="//div[@class='oe_title']" position="after">
                <group>
                    <group>
                        <field name="partner_id" options="{'no_create': True, 'no_open': True}" />
                        <field name="partner_code"/>
                        <field name="product_template_id" options="{'no_create': True, 'no_open': True}"  domain="[('detailed_type', '=', 'service')]"/>
                    </group>
                    <group>
                        <field name="user_id" domain="[('share', '=', False)]" widget="many2one_avatar_user" options="{'no_create': True, 'no_open': True}"/>
                        <field name="background_image" string="表單背景圖" widget="image" options="{'size': [90, 90]}"/>
                    </group>
                </group>
            </xpath>
            <xpath expr="//field[@name='constr_mandatory']" position="attributes">
                <attribute name="optional">show</attribute>
            </xpath>
            <xpath expr="//page[@name='questions']//field[@name='question_and_page_ids']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
            <xpath expr="//page[@name='questions']//tree//field[@name='constr_mandatory']" position="after">
                <field name="odoo_field_id_to"/>
            </xpath>
        </field>
    </record>

    <!-- 問題點開可填對應欄位 -->
    <record id="idx_survey_question_form_inherit_odoo_mapping" model="ir.ui.view">
        <field name="name">survey.question.form.inherit.odoo.mapping</field>
        <field name="model">survey.question</field>
        <field name="inherit_id" ref="survey.survey_question_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='question_type']" position="after">
                <field name="category" invisible="1"/>
                <field name="odoo_field_id_from"/>
                <field name="odoo_model_id_to" options="{'no_create': True, 'no_edit': True}"/>
                <field name="odoo_field_id_to" domain="[('model_id', '=', odoo_model_id_to)]" options="{'no_create': True, 'no_edit': True}"/>
            </xpath>
        </field>
    </record>

    <!-- 標題右邊增加公司LOGO，下方增加客戶名稱 -->
    <template id="idx_survey_fill_header_inherit" inherit_id="survey.survey_fill_header">
        <xpath expr="//div[contains(@class, 'o_survey_timer')]" position="replace">
            <div class="col-lg-2 pt-4 text-end">
                <t t-if="request.env.company and request.env.company.logo">
                    <img
                        t-att-src="'/web/image/res.company/%s/logo_web' % request.env.company.id"
                        style="max-height:60px; object-fit:contain;"
                        alt="Company Logo"/>
                </t>
            </div>
        </xpath>
        <xpath expr="//h1[@t-esc='survey.title']" position="after">
            <t t-if="survey.partner_id">
                <div class="o_survey_partner_name h2 text-muted">
                    <t t-esc="survey.partner_id.name"/>
                </div>
            </t>
        </xpath>
    </template>

    <!-- 開始調查按鈕顏色變換 -->
    <template id="idx_survey_fill_form_start_inherit" inherit_id="survey.survey_fill_form_start">
        <xpath expr="//button[contains(@class, 'btn-primary')]" position="attributes">
            <attribute name="style">background-color:#305bab; border-color:#305bab; color:#ffffff;</attribute>
        </xpath>
    </template>

    <!-- 問卷來源預設 -->
    <template id="idx_survey_question_char_box"
              inherit_id="survey.question_char_box">
        <xpath expr="//input[contains(@class, 'o_survey_question_text_box')]"
               position="attributes">
            <attribute name="t-att-value">
                answer_lines[0].value_char_box
                if answer_lines
                else question._get_default_char_box_value()
            </attribute>
        </xpath>
    </template>

    <!-- 隱藏由Odoo驅動 -->
    <template id="idx_survey_layout_hide_brand" inherit_id="survey.layout">
        <xpath expr="//div[contains(@class, 'o_survey_brand_message')]" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
    </template>

    <!-- QRCode表單 Action -->
    <record id="idx_action_survey_survey_form" model="ir.actions.act_window">
        <field name="name">QRCode表單</field>
        <field name="res_model">survey.survey</field>
        <field name="view_mode">tree,form</field>
        <field name="context">
            {
                'default_survey_type': 'assessment',
                'default_scoring_type': 'no_scoring',
                'default_questions_layout': 'one_page',
                'default_access_mode': 'public'
            }
        </field>
    </record>

    <!-- QRCode表單 Menu -->
    <menuitem
        id="idx_menu_survey_survey_form"
        name="QRCode表單"
        parent="website_sale.menu_orders"
        action="idx_action_survey_survey_form"
        sequence="2"
    />

    <!-- 隱藏問卷調查的menuitem -->
    <record id="survey.menu_surveys" model="ir.ui.menu">
        <field name="active">False</field>
    </record>

</odoo>
