<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="idx_merge_order_wizard_form" model="ir.ui.view">
        <field name="name">idx.merge.order.wizard.form</field>
        <field name="model">idx.merge.order.wizard</field>
        <field name="arch" type="xml">
            <form string="合併成訂單">
                <group>
                    <field name="start_date"/>
                    <field name="end_date"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            type="object"
                            string="確認"
                            class="btn-primary"/>
                    <button string="取消"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>