<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pricelist_wf_sync_wizard_form" model="ir.ui.view">
        <field name="name">pricelist.wf.sync.wizard.form</field>
        <field name="model">pricelist.wf.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="價格表同步至B2B">
                <group string="請選擇[報價日期]範圍">
                    <field string="起始日期" name="quote_date_start"/>
                    <field string="結束日期" name="quote_date_end"/>
                </group>
                <group string="請選擇[建立日期]範圍">
                    <field string="起始日期" name="create_date_start"/>
                    <field string="結束日期" name="create_date_end"/>
                </group>
                <group string="請選擇[修改日期]範圍">
                    <field string="起始日期" name="modi_date_start"/>
                    <field string="結束日期" name="modi_date_end"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            type="object"
                            string="確認"
                            class="btn-primary"/>
                    <button string="取消"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>