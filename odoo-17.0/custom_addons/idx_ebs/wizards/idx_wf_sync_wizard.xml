<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="idx_wf_sync_wizard_form" model="ir.ui.view">
        <field name="name">idx.wf.sync.wizard.form</field>
        <field name="model">idx.wf.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="WF同步至B2B">
                <group string="新品號核准日期條件">
                    <field string="起始日期" name="approve_date_start"/>
                    <field string="起始日期" name="approve_date_end"/>
                </group>
                <group string="請選擇[建立日期]範圍">
                    <field string="起始日期" name="create_date_start"/>
                    <field string="起始日期" name="create_date_end"/>
                </group>
                <group string="請選擇[修改日期]範圍">
                    <field string="起始日期" name="write_date_start"/>
                    <field string="起始日期" name="write_date_end"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            type="object"
                            string="確認"
                            class="btn-primary"/>
                    <button string="取消"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="idx_wf_sync_wizard_form2" model="ir.ui.view">
        <field name="name">idx.wf.sync.wizard.form2</field>
        <field name="model">idx.wf.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="WF同步至B2B">
                <group>
                    <field string="品號" name="default_code"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            type="object"
                            string="確認"
                            class="btn-primary"/>
                    <button string="取消"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>