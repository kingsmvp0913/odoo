<odoo>
    <!-- 擴充 Portal 用戶查看訂單的權限，讓 partner_id 符合的訂單也能顯示 -->
    <record id="sale_order_portal_rule" model="ir.rule">
        <field name="name">Portal: 所有自己的訂單 (idx_ebs)</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="domain_force">[('partner_id', 'child_of', [user.commercial_partner_id.id])]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- 覆蓋 website_sale 模組的產品相關公開使用者權限，全部設為無權限 -->
    <!-- 注意：product.template 保持讀取權限以讓 URL routing 正常工作，但在 controller 層攔截 -->
    <record id="website_sale.access_product_product_public_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>
    <!-- product.template 保留原始的讀取權限（僅用於 URL routing），controller 會攔截未登入訪問 -->
    <record id="website_sale.access_product_template_public_public" model="ir.model.access">
        <field name="perm_read" eval="True"/>
    </record>
    <record id="website_sale.access_product_category_public_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>
    <record id="website_sale.access_product_tag_public_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>
    <record id="website_sale.access_product_public_category_public_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>
    <record id="website_sale.access_product_pricelist_public_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>
    <record id="website_sale.access_product_pricelist_item_public_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>
    <record id="website_sale.access_product_attribute_public_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>
    <record id="website_sale.access_product_attribute_value_public_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>
    <record id="website_sale.access_product_product_attribute_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>
    <record id="website_sale.access_product_product_attribute_custom_value_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>
    <record id="website_sale.access_product_template_attribute_exclusion_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>
    <record id="website_sale.access_product_template_attribute_line_public_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>
    <record id="website_sale.access_product_image_public_public" model="ir.model.access">
        <field name="perm_read" eval="False"/>
    </record>

