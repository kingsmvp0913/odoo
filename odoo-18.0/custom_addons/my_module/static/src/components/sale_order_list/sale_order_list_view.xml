<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="my_module.SaleListRendererExt" t-inherit="sale.SaleListRenderer" t-inherit-mode="extension">
        <xpath expr="//tfoot" position="inside">
            <t t-set="info" t-value="selectedAmountInfo"/>
            <tr t-if="info" class="o_sale_selected_total fw-bold">
                <td colspan="100" class="text-end pe-3 text-info">
                    已勾選 <t t-esc="info.count"/> 筆，小計：<t t-esc="info.formatted"/>
                </td>
            </tr>
        </xpath>
    </t>
</templates>
