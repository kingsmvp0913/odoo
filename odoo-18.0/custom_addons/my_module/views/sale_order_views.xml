<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.my.module</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <widget name="test"></widget>  
            </xpath>

            <xpath expr="//field[@name='order_line'][@widget='sol_o2m']" position="attributes">
                <attribute name="widget">sol_o2m_color</attribute>
            </xpath>

            <xpath expr="//notebook/page" position="before">
                <page name="focus_tab" string="點擊後focus">
                    <widget name="testRef"></widget>
                </page>
                <page name="calculator_tab" string="簡易計算機" class="js_calculator_tab">
                    <widget name="testCalculator"></widget>
                </page>
                <page name="example_tab" string="Example">
                    <widget name="example"></widget>
                </page>
            </xpath>
            
        </field>
    </record>

    <record id="sale_order_tree_inherit" model="ir.ui.view">
        <field name="name">sale.order.tree.inherit.checked.sum</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="js_class">sale_order_list</attribute>
            </xpath>
        </field>
    </record>
</odoo>
