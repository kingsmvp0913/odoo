<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
    <!-- Fallback for generic list views with account.move -->
    <t t-extend="ListView.buttons">
        <t t-jquery="button.o_list_export_xlsx" t-operation="after">
            <t t-if="widget.modelName == 'account.move'">
                <button type="button"
                        class="btn btn-secondary o_list_export_invo_csv"
                        title="導出財政部 CSV"
                        aria-label="導出財政部 CSV">
                    導出財政部 CSV
                </button>
            </t>
        </t>
    </t>
    <!-- Invoice list view uses BillsListController with buttons_template: 'BillsListView.buttons' -->
    <t t-extend="BillsListView.buttons">
        <t t-jquery="button.o_list_export_xlsx" t-operation="after">
            <button type="button"
                    class="btn btn-secondary o_list_export_invo_csv"
                    title="導出財政部 CSV"
                    aria-label="導出財政部 CSV">
                導出財政部 CSV
            </button>
        </t>
    </t>
</templates>
